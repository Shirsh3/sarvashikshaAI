# Copy this file to application-local.properties and fill in your actual values.
# application-local.properties is gitignored — never commit real secrets.
# Run locally with: spring.profiles.active=local (or set in IDE/command line).
#
# Local uses PostgreSQL. Create a DB (e.g. createdb sarvsikshaai) and set:
# spring.datasource.url=jdbc:postgresql://localhost:5432/sarvsikshaai
# spring.datasource.username=postgres
# spring.datasource.password=yourpassword
#
# Key (local file)                  → Env var (Render)            Example
# openai.api-key                   → OPENAI_API_KEY             sk-proj-xxx
# youtube.dataKey                  → YOUTUBE_DATAKEY             AIzaSyxxx
# spring...google.client-id        → ...GOOGLE_CLIENT_ID         xxx.apps.googleusercontent.com
# spring...google.client-secret    → ...GOOGLE_CLIENT_SECRET     GOCSPX-xxx
# SPRING_DATASOURCE_URL            → (Render Postgres)           jdbc:postgresql://host:5432/db
# SPRING_DATASOURCE_USERNAME       → (Render Postgres)
# SPRING_DATASOURCE_PASSWORD       → (Render Postgres)

openai.api-key=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
youtube.dataKey=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
spring.security.oauth2.client.registration.google.client-id=123456789-xxx.apps.googleusercontent.com
spring.security.oauth2.client.registration.google.client-secret=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# PostgreSQL (local)
spring.datasource.url=jdbc:postgresql://localhost:5432/sarvsikshaai
spring.datasource.username=postgres
spring.datasource.password=
